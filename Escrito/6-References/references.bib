@article{haleOpticalConstantsWater1973,
	title = {Optical Constants of Water in the 200-nm to 200-μm Wavelength Region},
	volume = {12},
	rights = {© 1973 Optical Society of America},
	issn = {2155-3165},
	url = {https://opg.optica.org/ao/abstract.cfm?uri=ao-12-3-555},
	doi = {10.1364/AO.12.000555},
	abstract = {Extinction coefficients k(λ) for water at 25°C were determined through a broad spectral region by manually smoothing a point by point graph of k(λ) vs wavelength λ that was plotted for data obtained from a review of the scientific literature on the optical constants of water. Absorption bands representing k(λ) were postulated where data were not available in the vacuum uv and soft x-ray regions. A subtractive Kramers-Kronig analysis of the combined postulated and smoothed portions of the k(λ) spectrum provided the index of refraction n(λ) for the spectral region 200 nm ≤ λ ≤ 200 μm.},
	pages = {555--563},
	number = {3},
	journaltitle = {Appl. Opt.},
	shortjournal = {Appl. Opt., {AO}},
	publisher = {Optica Publishing Group},
	author = {Hale, George M. and Querry, Marvin R.},
	date = {1973-03-01},
	keywords = {Refractive index, Absorption coefficient, Extinction coefficients, Optical computing, Optical constants, Optical properties},
	file = {Full Text PDF:C\:\\Users\\danal\\Zotero\\storage\\J6MJ5KZ4\\Hale y Querry - 1973 - Optical Constants of Water in the 200-nm to 200-μm Wavelength Region.pdf:application/pdf},
}

