 RowBox[{
  RowBox[{
   RowBox[{"parteReFit", "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"datosRE", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"datosRE", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nindexEriFit", "[", "lambda_", "]"}], ":=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{"parteReFit", "[", "lambda", "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"parteImFit", "[", "lambda", "]"}]}]}], "]"}]}]}], "Input",
