Cell[BoxData[
 RowBox[{
  RowBox[{"mieQsca", "[", 
   RowBox[{"np_", ",", "nm_", ",", "a_", ",", "lambda_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "nmax", ",", "an", ",", "bn", ",", "k", ",", "Csca", ",", "Qsca"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nmax", "=", 
      RowBox[{"criterioWiscombe", "[", 
       RowBox[{"nm", ",", "a", ",", "lambda"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"an", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"mieCoefAn", "[", 
         RowBox[{"np", ",", "nm", ",", "a", ",", "lambda", ",", "#"}], "]"}], 
        "&"}], "/@", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", "nmax"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bn", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"mieCoefBn", "[", 
         RowBox[{"np", ",", "nm", ",", "a", ",", "lambda", ",", "#"}], "]"}], 
        "&"}], "/@", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", "nmax"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Csca", "=", " ", 
      RowBox[{
       FractionBox[
        RowBox[{"(", 
         RowBox[{"lambda", "^", "2"}], " ", ")"}], 
        RowBox[{"(", 
         RowBox[{"2", "*", "\[Pi]", "*", " ", 
          RowBox[{
           RowBox[{"Norm", "[", "nm", "]"}], "^", "2"}]}], ")"}]], "*", 
       RowBox[{"(", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "n"}], " ", "+", "1"}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Norm", "[", 
               RowBox[{"an", "[", 
                RowBox[{"[", "n", "]"}], "]"}], " ", "]"}], "^", "2"}], "+", 
             RowBox[{
              RowBox[{"Norm", "[", 
               RowBox[{"bn", "[", 
                RowBox[{"[", "n", "]"}], "]"}], "]"}], " ", "^", "2"}]}], 
            ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "nmax"}], "}"}]}], "]"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Qsca", "=", 
      FractionBox["Csca", 
       RowBox[{"Pi", "*", " ", 
        RowBox[{"a", "^", "2"}]}]]}], " ", ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"an", ",", "bn", ",", "Csca", ",", "Qsca"}], "}"}]}]}], 
   "]"}]}]], "Input",
