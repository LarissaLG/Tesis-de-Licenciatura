Cell[CellGroupData[{

Cell["Ajuste de lorentzianas", "Subsection",
 CellChangeTimes->{{3.9851914829077187`*^9, 
  3.98519148900266*^9}},ExpressionUUID->"1ebd0ba6-17e8-415c-9372-\
5a4015d7e537"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Funci\[OAcute]n", " ", "diel\[EAcute]ctrica", " ", "experimental"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"epsPlasmaIm", "[", "x_", "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRePlasma", ",", "parteImPlasma", ",", "x"}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsPlasmaRe", "[", "x_", "]"}], ":=", 
     RowBox[{"Re", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRePlasma", ",", "parteImPlasma", ",", "x"}], "]"}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Intervalos", " ", "de", " ", "b\[UAcute]squeda", " ", "de", " ", "los", 
     " ", "m\[AAcute]ximos"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"intervalosPlasma", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
