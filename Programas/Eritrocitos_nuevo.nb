       RowBox[{"(*", 
        RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
       RowBox[{"dif", "=", 
        RowBox[{"espectro", "-", "datosRealObjetivo28"}]}], ";", 
       "\[IndentingNewLine]", "                    ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"dif", "^", "2"}], "]"}], "/", 
         RowBox[{"Length", "[", "datosRealObjetivo28", "]"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n", "                    "}], "\n", 
