Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Funci\[OAcute]n", " ", "diel\[EAcute]ctrica", " ", "experimental"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"eps34Im", "[", "x_", "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRe34", ",", "parteIm34", ",", "x"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"eps34Re", "[", "x_", "]"}], ":=", 
