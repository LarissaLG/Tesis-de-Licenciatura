Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "ignorando", " ", "el", " ", 
    "pico", " ", "peque\[NTilde]o", " ", "faltante"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xmin15", ",", "xmax15"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Min", "[", "datos2im", "]"}], ",", 
       RowBox[{"Max", "[", "datos2im", "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"eps15Data0", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps15Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xmin15", ",", "2.65", ",", "0.01"}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eps15Data1", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps15Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.76", ",", "xmax15", ",", "0.01"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eps15Data2", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"eps15Data0", ",", "eps15Data1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eps15Data", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps15Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xmin15", ",", "xmax15", ",", "0.01"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fit15", " ", "=", " ", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps15Data2", ",", "\n", "                           ", 
       RowBox[{"lorentzSumIm", "[", 
        RowBox[{"\[Omega]", ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "A1", ",", " ", "A2", ",", " ", "A3", ",", " ", "A4", ",", " ", 
           "A5"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "\[Omega]01", ",", " ", "\[Omega]02", ",", " ", "\[Omega]03", ",", 
