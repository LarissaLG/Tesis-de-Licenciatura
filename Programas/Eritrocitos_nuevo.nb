Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"datosuA30", "=", 
    RowBox[{
    "Import", "[", 
     "\"\<C:\\\\Users\\\\danal\\\\Documents\\\\Grupo_Nanoplasm\[OAcute]nica\\\
\\Tesis\\\\Refractive index\\\\30.6_uA_Erythrocytes.csv\>\"", "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "eliminan", " ", "los", " ", "encabezados", " ", "de", " ", 
    "los", " ", "datos"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"datos1uA30", "=", 
    RowBox[{"Drop", "[", 
     RowBox[{"datosuA30", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "pasa", " ", "de", " ", "longitudes", " ", "de", " ", "onda", 
    " ", "a", " ", "energ\[IAcute]as", " ", "y", " ", "se", " ", "toma", " ", 
    "a", " ", "la", " ", "primera", " ", "columna", " ", "como", " ", "el", 
    " ", "vector", " ", "de", " ", "energ\[IAcute]as"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"datos2im30", "=", 
    RowBox[{"h", " ", 
     RowBox[{"c", "/", 
      RowBox[{"datos1uA30", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Obtener", " ", "la", " ", "parte", " ", "imaginariad", " ", "del", " ", 
    "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "a", " ", 
    "partir", " ", "del", " ", "coeficiente", " ", "de", " ", 
    "absorci\[OAcute]n"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"datos3im30", "=", 
    RowBox[{
     RowBox[{"datos1uA30", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}], "*", 
     RowBox[{"10", "^", 
      RowBox[{"(", 
       RowBox[{"-", "6"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{"datos1uA30", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"4", "*", "Pi"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "interpolan", " ", "los", " ", "datos", " ", "de", " ", "la", 
    " ", "parte", " ", "imaginaria"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parteIm30", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"datos2im30", ",", "datos3im30"}], "}"}], "]"}], ",", 
     RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRe30", "[", "x_", "]"}], ":=", 
