        RowBox[{"{", "\"\<Datos sin ajustar\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", "\n", "        ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fit301", "[", "\[Omega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", "2.55", ",", "3.5"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
