Cell["Ajuste sin el pico peque\[NTilde]o", "Subsubsection",
 CellChangeTimes->{{3.985193006548394*^9, 
  3.985193014718075*^9}},ExpressionUUID->"32fb4e33-db85-416d-a6d0-\
97be60698086"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Funci\[OAcute]n", " ", "diel\[EAcute]ctrica", " ", "experimental"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"eps30Im", "[", "x_", "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRe30", ",", "parteIm30", ",", "x"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"eps30Re", "[", "x_", "]"}], ":=", 
     RowBox[{"Re", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRe30", ",", "parteIm30", ",", "x"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Intervalos", " ", "de", " ", "b\[UAcute]squeda", " ", "de", " ", "los", 
     " ", "m\[AAcute]ximos"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"intervalos30", "=", 
