Cell["Ajuste de lorentzianas", "Subsection",
 CellChangeTimes->{{3.9851914829077187`*^9, 
  3.98519148900266*^9}},ExpressionUUID->"1ebd0ba6-17e8-415c-9372-\
5a4015d7e537"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Funci\[OAcute]n", " ", "diel\[EAcute]ctrica", " ", "experimental"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"epsPlasmaIm", "[", "x_", "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRePlasma", ",", "parteImPlasma", ",", "x"}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsPlasmaRe", "[", "x_", "]"}], ":=", 
     RowBox[{"Re", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"parteRePlasma", ",", "parteImPlasma", ",", "x"}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Intervalos", " ", "de", " ", "b\[UAcute]squeda", " ", "de", " ", "los", 
     " ", "m\[AAcute]ximos"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"intervalosPlasma", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1.2", ",", "1.3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"2.57", ",", "2.8"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"2.8", ",", "2.9"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"3.4", ",", "3.5"}], "}"}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"\[Omega]0iPlasma", "=", 
     RowBox[{"\[Omega]0i", "[", 
      RowBox[{"epsPlasmaIm", ",", "intervalosPlasma"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"epsPlasmaRe", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.6", ",", "3"}], "}"}]}], "]"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"epsPlasmaIm", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.6", ",", "3"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Code",
