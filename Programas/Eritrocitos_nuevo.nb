Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "del", " ", "pico", " ", 
    "peque\[NTilde]o"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eps28Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps28Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.68", ",", "2.78", ",", "0.001"}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"fit281", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps28Data3", ",", 
       RowBox[{"A1", "*", 
        RowBox[{"lorentzIm", "[", 
         RowBox[{"\[Omega]", ",", "\[Omega]01", ",", "\[Gamma]1"}], "]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.0005"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", "2.7"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.15"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
