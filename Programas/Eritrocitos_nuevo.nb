 RowBox[{"                  ", 
  RowBox[{
   RowBox[{
    RowBox[{"funcionError28", "[", 
     RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
