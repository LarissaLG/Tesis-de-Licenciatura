Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"xminPlasma", ",", "xmaxPlasma"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Min", "[", "datos2imPlasma", "]"}], ",", 
      RowBox[{"Max", "[", "datos2imPlasma", "]"}]}], "}"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"epsPlasmaData", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"epsPlasmaIm", "[", "x", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "xminPlasma", ",", "xmaxPlasma", ",", "0.001"}], 
       "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fitPlasma", " ", "=", " ", 
    RowBox[{"NonlinearModelFit", "[", 
     RowBox[{"epsPlasmaData", ",", "\n", "                           ", 
      RowBox[{"{", 
       RowBox[{"lorentzSumIm", "[", 
        RowBox[{"\[Omega]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"A1", ",", " ", "A2", ",", " ", "A3", ",", " ", "A4"}], 
          "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "\[Omega]01", ",", " ", "\[Omega]02", ",", " ", "\[Omega]03", ",", 
           " ", "\[Omega]04"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "\[Gamma]1", ",", " ", "\[Gamma]2", ",", " ", "\[Gamma]3", ",", " ",
            "\[Gamma]4"}], "}"}]}], " ", "]"}], "}"}], ",", " ", "\n", 
      "             ", "\n", "                          ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"A1", ",", "0.001"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Omega]01", ",", 
          RowBox[{"\[Omega]0iPlasma", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Gamma]1", ",", "0.05"}], "}"}], ",", "\n", 
        "                          ", 
        RowBox[{"{", 
         RowBox[{"A2", ",", "0.000001"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Omega]02", ",", 
          RowBox[{"\[Omega]0iPlasma", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Gamma]2", ",", "0.05"}], "}"}], ",", "\n", 
