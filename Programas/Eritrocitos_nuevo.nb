Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "del", " ", "pico", " ", 
    "peque\[NTilde]o"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eps15Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps15Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.68", ",", "2.77", ",", "0.001"}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"fit151", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps15Data3", ",", 
       RowBox[{"A1", "*", 
        RowBox[{"lorentzIm", "[", 
         RowBox[{"\[Omega]", ",", "\[Omega]01", ",", "\[Gamma]1"}], "]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.0001"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", "2.75"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.005"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"eps15Data3", ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
       RowBox[{"PlotLegends", "->", 
