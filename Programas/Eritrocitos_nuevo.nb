Cell["Importaci\[OAcute]n de datos", "Subsection",
 CellChangeTimes->{{3.9851914558803196`*^9, 
  3.9851914624929285`*^9}},ExpressionUUID->"82994470-3d58-47fa-b620-\
f78dbd0a9322"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "van", " ", "a", " ", "importar", " ", "los", " ", "datos", " ",
     "de", " ", "la", " ", "parte", " ", "real", " ", "del", " ", 
    "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "y", " ", 
    "del", " ", "coeficiente", " ", "de", " ", "absorci\[OAcute]n"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"datosuAPlasma", "=", 
     RowBox[{
     "Import", "[", 
      "\"\<C:\\\\Users\\\\danal\\\\Documents\\\\Grupo_Nanoplasm\[OAcute]nica\\\
\\Tesis\\\\Refractive index\\\\uA_ImN_Plasma2.csv\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datosRePlasma", "=", 
     RowBox[{
     "Import", "[", 
      "\"\<C:\\\\Users\\\\danal\\\\Documents\\\\Grupo_Nanoplasm\[OAcute]nica\\\
\\Tesis\\\\Refractive index\\\\ReN_Plasma.csv\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "eliminan", " ", "los", " ", "encabezados", " ", "de", " ", 
     "los", " ", "datos"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1uAPlasma", "=", 
     RowBox[{"Drop", "[", 
      RowBox[{"datosuAPlasma", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1RePlasma", "=", 
     RowBox[{"Drop", "[", 
      RowBox[{"datosRePlasma", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "pasa", " ", "de", " ", "longitudes", " ", "de", " ", "onda", 
     " ", "a", " ", "energ\[IAcute]as", " ", "y", " ", "se", " ", "toma", " ",
      "a", " ", "la", " ", "primera", " ", "columna", " ", "como", " ", "el", 
     " ", "vector", " ", "de", " ", "energ\[IAcute]as"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos2imPlasma", "=", 
     RowBox[{"h", " ", 
      RowBox[{"c", "/", 
       RowBox[{"datos1uAPlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos2rePlasma", "=", 
     RowBox[{"h", " ", 
      RowBox[{"c", "/", 
       RowBox[{"datos1RePlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Obtener", " ", "la", " ", "parte", " ", "imaginariad", " ", "del", " ", 
     "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "a", " ", 
     "partir", " ", "del", " ", "coeficiente", " ", "de", " ", 
     "absorci\[OAcute]n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos3imPlasma", "=", 
     RowBox[{
      RowBox[{"datos1uAPlasma", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "*", 
      RowBox[{"10", "^", 
       RowBox[{"(", 
        RowBox[{"-", "6"}], ")"}]}], "*", 
      RowBox[{
       RowBox[{"datos1uAPlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", "Pi"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "interpolan", " ", "los", " ", "datos", " ", "de", " ", "la", 
     " ", "parte", " ", "imaginaria"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteImPlasma", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"datos2imPlasma", ",", "datos3imPlasma"}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteRePlasma", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"datos2rePlasma", ",", 
         RowBox[{"datos1RePlasma", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"parteImPlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.2", ",", "3.53"}], "}"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"parteRePlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.66", ",", "3.09"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Code",
 CellChangeTimes->{{3.98519132371327*^9, 3.9851913249046607`*^9}, {
