Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "del", " ", "pico", " ", 
    "peque\[NTilde]o"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eps30Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps30Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.72", ",", "2.74", ",", "0.0007"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fit301", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps30Data3", ",", 
       RowBox[{"A1", "*", 
        RowBox[{"lorentzIm", "[", 
         RowBox[{"\[Omega]", ",", "\[Omega]01", ",", "\[Gamma]1"}], "]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.0001"}], "}"}], ",", 
         RowBox[{"{", 
