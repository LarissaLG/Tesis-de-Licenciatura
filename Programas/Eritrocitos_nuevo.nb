Cell[BoxData[{
 RowBox[{
  RowBox[{"h2olambda", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"datos1H2O", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "*", "1000"}], ",", 
       RowBox[{"datos1H2O", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"betalambda", "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"datos1Beta", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"datos1Beta", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "va", " ", "a", " ", "encontrar", " ", "la", " ", "parte", " ", 
    "real", " ", "empleando", " ", "la", " ", "relaci\[OAcute]n", " ", "de", 
    " ", "Meinke", " ", "2006"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRelambda", "[", 
    RowBox[{"x_", ",", "C_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"h2olambda", "[", "x", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"betalambda", "[", "x", "]"}], "*", "C"}], ")"}], "+", "1"}], 
     ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRe28lambda", "[", "x_", "]"}], ":=", 
   RowBox[{"parteRelambda", "[", 
    RowBox[{"x", ",", "28.7"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRe34lambda", "[", "x_", "]"}], ":=", 
   RowBox[{"parteRelambda", "[", 
    RowBox[{"x", ",", "34"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRe30lambda", "[", "x_", "]"}], ":=", 
   RowBox[{"parteRelambda", "[", 
    RowBox[{"x", ",", "30.6"}], "]"}]}], ";"}]}], "Code",
