Cell[BoxData[{
 RowBox[{
  RowBox[{"parteIm030", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fit30", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.19", ",", "4.96", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parteIm03010", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fit30", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "omega10"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"omegaprueba30", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"2.11", ",", "4.95", ",", "0.01"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"datosRealObjetivo30", "=", 
   RowBox[{"eps30Re", "/@", "omegaprueba30"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"                  ", 
  RowBox[{
   RowBox[{
    RowBox[{"funcionError30", "[", 
     RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
        "ancla"}], "*)"}], "\[IndentingNewLine]", "                  ", 
      RowBox[{
       RowBox[{"epsAnchor", "=", 
        RowBox[{"eps30Re", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
       "                    ", 
       RowBox[{"(*", 
        RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
       RowBox[{"espectro", "=", 
        RowBox[{"sskkrebook", "[", 
         RowBox[{
         "omegaprueba30", ",", "parteIm030", ",", "w", ",", "epsAnchor"}], 
         "]"}]}], ";", "\[IndentingNewLine]", "                      ", 
       RowBox[{"(*", 
        RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
       RowBox[{"dif", "=", 
        RowBox[{"espectro", "-", "datosRealObjetivo30"}]}], ";", 
       "\[IndentingNewLine]", "                    ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"dif", "^", "2"}], "]"}], "/", 
         RowBox[{"Length", "[", "datosRealObjetivo30", "]"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n", "                    "}], "\n", 
 RowBox[{
  RowBox[{"error30", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"funcionError30", "[", "w", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "2.05", ",", "3.1", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"MinimalBy", "[", 
  RowBox[{"error30", ",", "Last"}], "]"}]}], "Code",
