   RowBox[{
    RowBox[{"eps28Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps28Im", "[", "x", "]"}]}], "}"}], ",", 
