      RowBox[{
       RowBox[{"fit151", "[", "\[Omega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", "2.55", ",", "3.5"}], "}"}], ",", "\n", 
       "      ", 
