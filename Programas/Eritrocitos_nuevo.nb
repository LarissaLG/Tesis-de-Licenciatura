Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"parteIm034", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fit34tot", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.19", ",", "4.96", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parteIm03410", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fit34tot", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "omega10"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"omegaprueba34", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"2.11", ",", "4.95", ",", "0.01"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"datosRealObjetivo34", "=", 
   RowBox[{"eps34Re", "/@", "omegaprueba34"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"                  ", 
  RowBox[{
   RowBox[{
    RowBox[{"funcionError34", "[", 
     RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
        "ancla"}], "*)"}], "\[IndentingNewLine]", "                  ", 
      RowBox[{
       RowBox[{"epsAnchor", "=", 
        RowBox[{"eps34Re", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
       "                    ", 
       RowBox[{"(*", 
        RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
       RowBox[{"espectro", "=", 
        RowBox[{"sskkrebook", "[", 
         RowBox[{
         "omegaprueba34", ",", "parteIm034", ",", "w", ",", "epsAnchor"}], 
         "]"}]}], ";", "\[IndentingNewLine]", "                      ", 
       RowBox[{"(*", 
        RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
       RowBox[{"dif", "=", 
        RowBox[{"espectro", "-", "datosRealObjetivo34"}]}], ";", 
       "\[IndentingNewLine]", "                    ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"dif", "^", "2"}], "]"}], "/", 
         RowBox[{"Length", "[", "datosRealObjetivo34", "]"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n", "                    "}], "\n", 
 RowBox[{
  RowBox[{"error34", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"funcionError34", "[", "w", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "2.05", ",", "3.1", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"MinimalBy", "[", 
  RowBox[{"error34", ",", "Last"}], "]"}]}], "Code",
