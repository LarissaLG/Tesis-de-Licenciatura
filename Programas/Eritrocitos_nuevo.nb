Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "del", " ", "pico", " ", 
    "peque\[NTilde]o"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eps30Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps30Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.72", ",", "2.74", ",", "0.0007"}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"fit301", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps30Data3", ",", 
       RowBox[{"A1", "*", 
        RowBox[{"lorentzIm", "[", 
         RowBox[{"\[Omega]", ",", "\[Omega]01", ",", "\[Gamma]1"}], "]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.0001"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", "2.75"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.01"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"eps30Data3", ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<Datos sin ajustar\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", "\n", "        ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fit301", "[", "\[Omega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", "2.55", ",", "3.5"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<Ajuste Lorentz\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "]"}], "\n", "        ",
    "\[IndentingNewLine]", 
   RowBox[{"ScientificForm", "[", 
    RowBox[{
     RowBox[{"fit301", "[", "\"\<BestFitParameters\>\"", "]"}], ",", "3"}], 
    "]"}], "\[IndentingNewLine]", 
   RowBox[{"fit301Values", "=", 
    RowBox[{"Values", "[", 
     RowBox[{"fit301", "[", "\"\<BestFitParameters\>\"", "]"}], 
