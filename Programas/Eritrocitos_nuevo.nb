      RowBox[{"\[Omega]", ",", "2.55", ",", "5"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"ScientificForm", "[", 
    RowBox[{
     RowBox[{"fit151", "[", "\"\<BestFitParameters\>\"", "]"}], ",", "3"}], 
    "]"}], "\[IndentingNewLine]", 
