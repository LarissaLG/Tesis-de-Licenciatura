   RowBox[{
    RowBox[{"h2o", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"datos2H2O", ",", 
         RowBox[{"datos1H2O", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "va", " ", "a", " ", "encontrar", " ", "la", " ", "parte", " ",
      "real", " ", "empleando", " ", "la", " ", "relaci\[OAcute]n", " ", "de",
      " ", "Meinke", " ", "2006"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"parteRe", "[", 
      RowBox[{"x_", ",", "C_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"h2o", "[", "x", "]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"beta", "[", "x", "]"}], "*", "C"}], ")"}], "+", "1"}], 
       ")"}]}]}], ";"}]}]}]], "Code",
