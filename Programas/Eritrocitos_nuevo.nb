9fc3d8480c88"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"parteIm0Plasma", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fitPlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.19", ",", "4.96", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parteIm0Plasma10", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fitPlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "omega10"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"omegapruebaPlasma", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"2.11", ",", "4.95", ",", "0.01"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"datosRealObjetivoPlasma", "=", 
   RowBox[{"epsPlasmaRe", "/@", "omegapruebaPlasma"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"                  ", 
  RowBox[{
   RowBox[{
    RowBox[{"funcionErrorPlasma", "[", 
     RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
        "ancla"}], "*)"}], "\[IndentingNewLine]", "                  ", 
      RowBox[{
       RowBox[{"epsAnchor", "=", 
        RowBox[{"eps34Re", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
       "                    ", 
       RowBox[{"(*", 
        RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
       RowBox[{"espectro", "=", 
        RowBox[{"sskkrebook", "[", 
         RowBox[{
         "omegapruebaPlasma", ",", "parteIm0Plasma", ",", "w", ",", 
          "epsAnchor"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "                      ", 
       RowBox[{"(*", 
        RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
       RowBox[{"dif", "=", 
        RowBox[{"espectro", "-", "datosRealObjetivoPlasma"}]}], ";", 
       "\[IndentingNewLine]", "                    ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"dif", "^", "2"}], "]"}], "/", 
         RowBox[{"Length", "[", "datosRealObjetivoPlasma", "]"}]}], "]"}]}]}],
      "]"}]}], ";"}], "\n", "                    "}], "\n", 
 RowBox[{
  RowBox[{"errorPlasma", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"funcionErrorPlasma", "[", "w", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "2.05", ",", "3.09", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"MinimalBy", "[", 
  RowBox[{"errorPlasma", ",", "Last"}], "]"}]}], "Code",
