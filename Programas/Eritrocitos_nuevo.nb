Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"epsRe", "[", 
    RowBox[{"parteRe_", ",", "parteIm_", ",", "x_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"parteRe", "[", "x", "]"}], "^", "2"}], "-", 
    RowBox[{
     RowBox[{"parteIm", "[", "x", "]"}], "^", "2"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"epsIm", "[", 
    RowBox[{"parteRe_", ",", "parteIm_", ",", "x_"}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{"2", "*", 
     RowBox[{"parteRe", "[", "x", "]"}], "*", 
     RowBox[{"parteIm", "[", "x", "]"}]}], ")"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"eps", "[", 
     RowBox[{"parteRe_", ",", "parteIm_", ",", "x_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"parteRe", "[", "x", "]"}], "+", 
       RowBox[{"I", " ", 
        RowBox[{"parteIm", "[", "x", "]"}]}]}], ")"}], "^", "2"}]}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Funci\[OAcute]n", " ", "para", " ", "encontrar", " ", "los", " ", 
    "m\[AAcute]ximos", " ", "alrededor", " ", "de", " ", "intervalos", " ", 
    "dados"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Omega]0i", "[", 
     RowBox[{"eps_", ",", "intervalos_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"GoldenSearchMax", "[", 
       RowBox[{"eps", ",", "##"}], "]"}], "&"}], "@@@", "intervalos"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{"Parte", " ", "imaginaria", " ", "de", " ", "lorentziana"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lorentzIm", "[", 
    RowBox[{"omega_", ",", "omega0_", ",", "gamma_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"gamma", " ", "omega"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"omega0", "^", "2"}], "-", 
         RowBox[{"omega", "^", "2"}]}], ")"}], "^", "2"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"gamma", " ", "omega"}], ")"}], "^", "2"}]}], ")"}]}]}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Suma", " ", "lorentzianas"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"lorentzSumIm", "[", 
   RowBox[{
   "omega_", ",", " ", "A_List", ",", " ", "omega0_List", ",", " ", 
    "gamma_List"}], "]"}], " ", ":=", "  ", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"[", "i", "]"}], "]"}], " ", "*", " ", 
     RowBox[{"lorentzIm", "[", 
      RowBox[{"omega", ",", " ", 
       RowBox[{"omega0", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
       RowBox[{"gamma", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", " ", 
    RowBox[{"{", 
