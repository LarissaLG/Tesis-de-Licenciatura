Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "del", " ", "pico", " ", 
    "peque\[NTilde]o"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eps34Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps34Im", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "2.72", ",", "2.74", ",", "0.0007"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fit341", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"eps34Data3", ",", 
       RowBox[{"A1", "*", 
        RowBox[{"lorentzIm", "[", 
         RowBox[{"\[Omega]", ",", "\[Omega]01", ",", "\[Gamma]1"}], "]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.0001"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", "2.75"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.01"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
