Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Datos", " ", "para", " ", "ajuste", " ", "ignorando", " ", "el", " ", 
    "pico", " ", "peque\[NTilde]o", " ", "faltante"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xminPlasma", ",", "xmaxPlasma"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Min", "[", "datos2imPlasma", "]"}], ",", 
       RowBox[{"Max", "[", "datos2imPlasma", "]"}]}], "}"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"epsPlasmaData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"epsPlasmaIm", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xminPlasma", ",", "xmaxPlasma", ",", "0.01"}], 
        "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fitPlasma", " ", "=", " ", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"epsPlasmaData", ",", "\n", "                           ", 
       RowBox[{"lorentzSumIm", "[", 
        RowBox[{"\[Omega]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"A1", ",", " ", "A2", ",", " ", "A3", ",", " ", "A4"}], 
          "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "\[Omega]01", ",", " ", "\[Omega]02", ",", " ", "\[Omega]03", ",", 
           " ", "\[Omega]04"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
          "\[Gamma]1", ",", " ", "\[Gamma]2", ",", " ", "\[Gamma]3", ",", " ",
            "\[Gamma]4"}], "}"}]}], " ", "]"}], ",", " ", "\n", 
       "             ", "\n", "                          ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", " ", "0.01"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", " ", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", " ", "0.05"}], "}"}], ",", " ", "\n", 
         "                           ", 
         RowBox[{"{", 
          RowBox[{"A2", ",", " ", "0.01"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Omega]02", ",", " ", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]2", ",", " ", "0.05"}], "}"}], ",", " ", "\n", 
         "                           ", 
         RowBox[{"{", 
          RowBox[{"A3", ",", " ", "0.01"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Omega]03", ",", " ", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]3", ",", " ", "0.05"}], "}"}], ",", " ", "\n", 
         "                           ", 
         RowBox[{"{", 
          RowBox[{"A4", ",", " ", "0.01"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Omega]04", ",", " ", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]4", ",", " ", "0.05"}], "}"}]}], "}"}], ",", " ", 
       "\n", "                            ", "\[Omega]"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Grafica", " ", "datos", " ", "originales", " ", "y", " ", "ajuste", " ", 
     "con", " ", "5", " ", "Lorentzianas"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"epsPlasmaData", ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<Datos sin ajustar\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", "\n", "            ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fitPlasma", "[", "\[Omega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", "xminPlasma", ",", "xmaxPlasma"}], "}"}], 
       ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<Ajuste Lorentz\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "]"}], "\n", 
   "              ", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"fitPlasma", "[", "\[Omega]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Omega]", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fitPlasmaValues", "=", 
     RowBox[{"Values", "[", 
      RowBox[{"fitPlasma", "[", "\"\<BestFitParameters\>\"", "]"}], "]"}]}], 
    ";"}], "\n", "\n", "\n"}]}]], "Code",
