         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.01"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", 
