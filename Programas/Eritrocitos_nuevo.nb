         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.01"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"eps30Data3", ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
