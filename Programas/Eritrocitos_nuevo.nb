          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "va", " ", "a", " ", "encontrar", " ", "la", " ", "parte", " ", 
    "real", " ", "empleando", " ", "la", " ", "relaci\[OAcute]n", " ", "de", 
    " ", "Meinke", " ", "2006"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRelambda", "[", 
    RowBox[{"x_", ",", "C_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"h2olambda", "[", "x", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"betalambda", "[", "x", "]"}], "*", "C"}], ")"}], "+", "1"}], 
     ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteRe28lambda", "[", "x_", "]"}], ":=", 
