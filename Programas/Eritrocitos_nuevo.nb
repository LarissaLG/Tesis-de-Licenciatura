Cell[CellGroupData[{

Cell["Importaci\[OAcute]n de datos", "Subsection",
 CellChangeTimes->{{3.9851914558803196`*^9, 
  3.9851914624929285`*^9}},ExpressionUUID->"ae2bbd59-aa03-498a-b37b-\
4beb404f59f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "van", " ", "a", " ", "importar", " ", "los", " ", "datos", " ",
     "de", " ", "la", " ", "parte", " ", "real", " ", "del", " ", 
    "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "y", " ", 
    "del", " ", "coeficiente", " ", "de", " ", "absorci\[OAcute]n"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"datosuA", "=", 
     RowBox[{
     "Import", "[", 
      "\"\<C:\\\\Users\\\\danal\\\\Documents\\\\Grupo_Nanoplasm\[OAcute]nica\\\
\\Tesis\\\\Refractive index\\\\15.3_uA_Erythrocytes.csv\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "eliminan", " ", "los", " ", "encabezados", " ", "de", " ", 
     "los", " ", "datos"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1uA", "=", 
     RowBox[{"Drop", "[", 
      RowBox[{"datosuA", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1uA", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"ToExpression", ",", "datos1uA", ",", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "pasa", " ", "de", " ", "longitudes", " ", "de", " ", "onda", 
     " ", "a", " ", "energ\[IAcute]as", " ", "y", " ", "se", " ", "toma", " ",
      "a", " ", "la", " ", "primera", " ", "columna", " ", "como", " ", "el", 
     " ", "vector", " ", "de", " ", "energ\[IAcute]as"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos2im", "=", 
     RowBox[{"h", " ", 
      RowBox[{"c", "/", 
       RowBox[{"datos1uA", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Obtener", " ", "la", " ", "parte", " ", "imaginaria", " ", "del", " ", 
     "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "a", " ", 
     "partir", " ", "del", " ", "coeficiente", " ", "de", " ", 
     "absorci\[OAcute]n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos3im", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"datos1uA", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "*", 
          RowBox[{"10", "^", 
           RowBox[{"(", 
            RowBox[{"-", "6"}], ")"}]}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"4", "*", "Pi"}], ")"}]}], ")"}], "*", 
      RowBox[{"datos1uA", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "interpolan", " ", "los", " ", "datos", " ", "de", " ", "la", 
     " ", "parte", " ", "imaginaria"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteIm15", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"datos2im", ",", "datos3im"}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteRe15", "[", "x_", "]"}], ":=", 
    RowBox[{"parteRe", "[", 
     RowBox[{"x", ",", "15.3"}], "]"}]}], "\n", "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"parteIm15", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "2.11", ",", "4.95"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"parteRe15", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.15", ",", "4.95"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Code",
