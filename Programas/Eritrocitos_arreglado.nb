Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "van", " ", "a", " ", "importar", " ", "los", " ", "datos", " ",
     "de", " ", "la", " ", "parte", " ", "real", " ", "del", " ", 
    "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "y", " ", 
    "del", " ", "coeficiente", " ", "de", " ", "absorci\[OAcute]n"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"datosuAPlasma", "=", 
     RowBox[{
     "Import", "[", 
      "\"\<C:\\\\Users\\\\Nanoplasmonics\\\\Documents\\\\Tesis\\\\Refractive \
index\\\\uA_ImN_Plasma.csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datosRePlasma", "=", 
     RowBox[{
     "Import", "[", 
      "\"\<C:\\\\Users\\\\Nanoplasmonics\\\\Documents\\\\Tesis\\\\Refractive \
index\\\\ReN_Plasma.csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "eliminan", " ", "los", " ", "encabezados", " ", "de", " ", 
     "los", " ", "datos"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1uAPlasma", "=", 
     RowBox[{"Drop", "[", 
      RowBox[{"datosuAPlasma", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos1RePlasma", "=", 
     RowBox[{"Drop", "[", 
      RowBox[{"datosRePlasma", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "pasa", " ", "de", " ", "longitudes", " ", "de", " ", "onda", 
     " ", "a", " ", "energ\[IAcute]as", " ", "y", " ", "se", " ", "toma", " ",
      "a", " ", "la", " ", "primera", " ", "columna", " ", "como", " ", "el", 
     " ", "vector", " ", "de", " ", "energ\[IAcute]as"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos2imPlasma", "=", 
     RowBox[{"h", " ", 
      RowBox[{"c", "/", 
       RowBox[{"datos1uAPlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos2rePlasma", "=", 
     RowBox[{"h", " ", 
      RowBox[{"c", "/", 
       RowBox[{"datos1RePlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Obtener", " ", "la", " ", "parte", " ", "imaginariad", " ", "del", " ", 
     "\[IAcute]ndice", " ", "de", " ", "refracci\[OAcute]n", " ", "a", " ", 
     "partir", " ", "del", " ", "coeficiente", " ", "de", " ", 
     "absorci\[OAcute]n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"datos3imPlasma", "=", 
     RowBox[{
      RowBox[{"datos1uAPlasma", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "*", 
      RowBox[{"10", "^", 
       RowBox[{"(", 
        RowBox[{"-", "6"}], ")"}]}], "*", 
      RowBox[{
       RowBox[{"datos1uAPlasma", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", "Pi"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "interpolan", " ", "los", " ", "datos", " ", "de", " ", "la", 
     " ", "parte", " ", "imaginaria"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteImPlasma", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"datos2imPlasma", ",", "datos3imPlasma"}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parteRePlasma", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"datos2rePlasma", ",", 
         RowBox[{"datos1RePlasma", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
    ";"}]}]}]], "Input",
