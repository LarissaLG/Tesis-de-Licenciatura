          RowBox[{"A1", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A2", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]02", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]2", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A3", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]03", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]3", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A4", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]04", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]4", ",", "0.05"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Grafica", " ", "datos", " ", "originales", " ", "y", " ", "ajuste", " ", 
     "con", " ", "5", " ", "Lorentzianas"}], "*)"}], "\n", 
