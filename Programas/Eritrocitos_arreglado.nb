        RowBox[{"{", "\"\<Datos sin ajustar\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fitPlasma", "[", "\[Omega]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", 
         RowBox[{"xminPlasma", "-", "0.5"}], ",", 
         RowBox[{"xmaxPlasma", "+", "0.5"}]}], "}"}], ",", 
