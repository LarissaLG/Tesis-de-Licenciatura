            RowBox[{"[", "4", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]4", ",", "0.05"}], "}"}]}], "}"}], ",", 
       "\[Omega]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Grafica", " ", "datos", " ", "originales", " ", "y", " ", "ajuste", " ", 
     "con", " ", "5", " ", "Lorentzianas"}], "*)"}], "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
