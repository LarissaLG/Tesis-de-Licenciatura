Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Ajuste", " ", "de", " ", "la", " ", "parte", " ", "imaginaria", " ", 
    "con", " ", "lorentzianas"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xminPlasma", ",", "xmaxPlasma"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Min", "[", "datos2imPlasma", "]"}], ",", 
       RowBox[{"Max", "[", "datos2imPlasma", "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Datos", " ", "para", " ", "ajuste"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"epsPlasmaData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"epsPlasma", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xminPlasma", ",", "xmaxPlasma", ",", "0.01"}], 
        "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Ajustar", " ", "con", " ", "NonlinearModelFit"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fitPlasma", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"epsPlasmaData", ",", 
       RowBox[{"lorentzSumIm4", "[", 
        RowBox[{
        "\[Omega]", ",", "A1", ",", "\[Omega]01", ",", "\[Gamma]1", ",", "A2",
          ",", "\[Omega]02", ",", "\[Gamma]2", ",", "A3", ",", "\[Omega]03", 
         ",", "\[Gamma]3", ",", "A4", ",", "\[Omega]04", ",", "\[Gamma]4"}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A1", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]01", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]1", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A2", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]02", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]2", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A3", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]03", ",", 
           RowBox[{"\[Omega]0iPlasma", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Gamma]3", ",", "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"A4", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Omega]04", ",", 
