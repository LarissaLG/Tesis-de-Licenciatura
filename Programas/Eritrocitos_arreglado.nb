   RowBox[{
    RowBox[{"eps15Data3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"eps15Im", "[", "x", "]"}]}], "}"}], ",", 
