   RowBox[{"Range", "[", 
    RowBox[{"2.11", ",", "4.95", ",", "0.01"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"datosRealObjetivo30", "=", 
   RowBox[{"eps30Re", "/@", "omegaprueba30"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"funcionError30", "[", 
    RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
       "ancla"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"epsAnchor", "=", 
       RowBox[{"eps30Re", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
      RowBox[{"espectro", "=", 
       RowBox[{"sskkrebook", "[", 
        RowBox[{
        "omegaprueba30", ",", "parteIm030", ",", "w", ",", "epsAnchor"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
      RowBox[{"dif", "=", 
       RowBox[{"espectro", "-", "datosRealObjetivo30"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"dif", "^", "2"}], "]"}], "/", 
        RowBox[{"Length", "[", "datosRealObjetivo30", "]"}]}], "]"}]}]}], 
    "]"}]}], ";"}]}], "Input",
