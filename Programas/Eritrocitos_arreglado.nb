Cell[BoxData[{
 RowBox[{
  RowBox[{"parteIm0Plasma", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"fitPlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.66", ",", "3.08", ",", "0.01"}], "}"}]}], "]"}]}], 
