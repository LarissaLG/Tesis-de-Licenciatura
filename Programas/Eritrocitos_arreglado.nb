 RowBox[{
  RowBox[{"datosRealObjetivo34", "=", 
   RowBox[{"eps34Re", "/@", "omegaprueba34"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"funcionError34", "[", 
    RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
       "ancla"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"epsAnchor", "=", 
       RowBox[{"eps34Re", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
      RowBox[{"espectro", "=", 
       RowBox[{"sskkrebook", "[", 
        RowBox[{
        "omegaprueba34", ",", "parteIm034", ",", "w", ",", "epsAnchor"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
      RowBox[{"dif", "=", 
       RowBox[{"espectro", "-", "datosRealObjetivo34"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"dif", "^", "2"}], "]"}], "/", 
        RowBox[{"Length", "[", "datosRealObjetivo34", "]"}]}], "]"}]}]}], 
    "]"}]}], ";"}]}], "Input",
