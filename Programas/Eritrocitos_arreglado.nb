    RowBox[{
     RowBox[{"fitPlasma", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"omegapruebaPlasma", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"1.66", ",", "3.08", ",", "0.01"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"datosRealObjetivoPlasma", "=", 
   RowBox[{"epsPlasmaRe", "/@", "omegapruebaPlasma"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"funcionErrorPlasma", "[", 
    RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"epsAnchor", ",", "espectro", ",", "dif"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "valor", " ", "de", " ", "epsReal", " ", "en", " ", "el", " ", 
       "ancla"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"epsAnchor", "=", 
       RowBox[{"epsPlasmaRe", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"ejecutar", " ", "modelo"}], "*)"}], 
      RowBox[{"espectro", "=", 
       RowBox[{"sskkrebook", "[", 
        RowBox[{
        "omegapruebaPlasma", ",", "parteIm0Plasma", ",", "w", ",", 
         "epsAnchor"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"error", " ", "cuadr\[AAcute]tico", " ", "total"}], "*)"}], 
      RowBox[{"dif", "=", 
       RowBox[{"espectro", "-", "datosRealObjetivoPlasma"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"dif", "^", "2"}], "]"}], "/", 
        RowBox[{"Length", "[", "datosRealObjetivoPlasma", "]"}]}], "]"}]}]}], 
    "]"}]}], ";"}]}], "Input",
