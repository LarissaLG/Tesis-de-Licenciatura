 RowBox[{
  RowBox[{"a", "=", "2.657"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"b", "=", "2.75"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "r_", "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"a", "^", "2"}]}], "-", 
      RowBox[{"r", "^", "2"}], "+", 
