Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "2.657"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"b", "=", "2.75"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "r_", "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"a", "^", "2"}]}], "-", 
      RowBox[{"r", "^", "2"}], "+", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"4", " ", 
         RowBox[{"a", "^", "2"}], " ", 
         RowBox[{"r", "^", "2"}]}], "+", 
        RowBox[{"b", "^", "4"}]}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CurlyEpsilon]", "=", "0.015"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rbc", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"r", " ", 
         RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[CurlyEpsilon]", " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"3", " ", "r"}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"2", " ", "\[CurlyPhi]"}], "]"}]}]}], ")"}]}], ",", 
        RowBox[{"r", " ", 
         RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[CurlyEpsilon]", " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"3", " ", "r"}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"2", " ", "\[CurlyPhi]"}], "]"}]}]}], ")"}]}], ",", 
        RowBox[{"f", "[", "r", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0", ",", "3.8"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[CurlyPhi]", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"PlotPoints", "->", "140"}], ",", 
      RowBox[{"Mesh", "->", "None"}], ",", 
      RowBox[{"ColorFunction", "->", 
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y", ",", "z", ",", "r", ",", "\[CurlyPhi]"}], 
          "}"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", "shade", "}"}], ",", 
           RowBox[{
            RowBox[{"shade", "=", 
             RowBox[{"0.65", "+", 
              RowBox[{"0.35", " ", 
               RowBox[{"(", 
                RowBox[{"1", "-", 
