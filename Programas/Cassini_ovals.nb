Cell[CellGroupData[{

Cell["C\[AAcute]lculo de volumen, \[AAcute]rea", "Subsubsection",
 CellChangeTimes->{{3.9912269359686365`*^9, 
  3.9912269429911675`*^9}},ExpressionUUID->"7566d386-a599-4b84-b6c3-\
b6f15eb3cadb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vol", " ", "=", " ", 
   RowBox[{"4", " ", "Pi", " ", "*", " ", 
    RowBox[{"NIntegrate", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"x", " ", "*", " ", 
       RowBox[{"cassiniTsi", "[", 
        RowBox[{"x", ",", 
         RowBox[{"a", "[", 
          RowBox[{"3.825", ",", "0.71"}], "]"}], ",", "3.825"}], "]"}]}], ",",
       " ", "\n", "   ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "0", ",", " ", "3.825"}], "}"}]}], "]"}]}]}], 
  "\n", "   "}], "\n", 
 RowBox[{"area", " ", "=", " ", 
  RowBox[{"4", " ", "Pi", " ", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"r", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"cassiniTsi", "[", 
           RowBox[{"r", ",", 
            RowBox[{"a", "[", 
             RowBox[{"3.825", ",", "0.71"}], "]"}], ",", "3.825"}], "]"}], 
          ")"}], "^", "2"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "3.825"}], "}"}]}], "]"}]}]}]}], "Code",
 CellChangeTimes->{{3.991241136010507*^9, 3.991241268136952*^9}},
 CellLabel->
  "In[863]:=",ExpressionUUID->"68c2690e-d7f3-4e35-b425-24be24410cd7"],

