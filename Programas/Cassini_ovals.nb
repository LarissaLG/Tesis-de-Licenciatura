      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"R", "^", "2"}], "-", " ", 
        RowBox[{"2", 
         RowBox[{"a", " ", "^", "2"}]}]}], "]"}]}], ")"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"a", "^", "2"}]}], "-", 
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"4", " ", 
