Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Definir", " ", "la", " ", "curva", " ", "de", " ", 
    "referencia", " ", "emp\[IAcute]rica", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Evans", "&"}], " ", "Fung"}], ")"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Rmax", "=", "3.825"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zEF", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", "/", "Rmax"}], ")"}], "^", "2"}]}], "]"}], "*", 
     RowBox[{"(", 
      RowBox[{"0.72", "+", 
       RowBox[{"4.152", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "/", "Rmax"}], ")"}], "^", "2"}]}], "-", 
       RowBox[{"3.426", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "/", "Rmax"}], ")"}], "^", "4"}]}]}], ")"}]}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Definir", " ", "tu", " ", "modelo", " ", 
     "param\[EAcute]trico", " ", 
     RowBox[{"(", 
      RowBox[{"\[CapitalOAcute]valo", " ", "de", " ", "Cassini"}], ")"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zCas", "[", 
     RowBox[{"x_", ",", "a_", ",", "b_", ",", "c_"}], "]"}], ":=", 
    RowBox[{"c", "*", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"a", "^", "2"}]}], "-", 
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"4", "*", 
          RowBox[{"x", "^", "2"}], "*", 
          RowBox[{"a", "^", "2"}]}], "+", 
         RowBox[{"b", "^", "4"}]}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Crear", " ", "la", " ", "Funci\[OAcute]n", " ", "de", " ", 
     "Error", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
       "Suma", " ", "de", " ", "los", " ", "Cuadrados", " ", "de", " ", "los",
         " ", "Errores"}], "-", "SSE"}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Comparamos", " ", "la", " ", "altura", " ", "de", " ", "ambas", " ", 
     "curvas", " ", "cada", " ", "0.05", " ", "micras", " ", "a", " ", "lo", 
     " ", "largo", " ", "del", " ", "radio"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"funcionError", "=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"zCas", "[", 
           RowBox[{"x", ",", "a", ",", "b", ",", "c"}], "]"}], "-", 
          RowBox[{"zEF", "[", "x", "]"}]}], ")"}], "^", "2"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "3.8", ",", "0.05"}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Definir", " ", "las", " ", "reglas", " ", 
     "biol\[OAcute]gicas", " ", "inquebrantables", " ", 
     RowBox[{"(", "Restricciones", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"restricciones", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"a", "^", "2"}], "+", 
         RowBox[{"b", "^", "2"}]}], "==", 
        RowBox[{"Rmax", "^", "2"}]}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Regla", " ", "1"}], ":", 
         RowBox[{
         "El", " ", "radio", " ", "exterior", " ", "debe", " ", "ser", " ", 
          "exactamente", " ", "3.825"}]}], "*)"}], 
       RowBox[{
        RowBox[{"c", "*", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"b", "^", "2"}], "-", 
           RowBox[{"a", "^", "2"}]}], "]"}]}], "==", "0.72"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Regla", " ", "2"}], ":", 
         RowBox[{
         "La", " ", "profundidad", " ", "central", " ", "debe", " ", "ser", 
          " ", "exactamente", " ", "0.72"}]}], "*)"}], 
       RowBox[{"a", ">", "0"}], ",", 
       RowBox[{"b", ">", "a"}], ",", 
       RowBox[{"c", ">", "0"}]}], "          ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Regla", " ", "3"}], ":", 
        RowBox[{
        "F\[IAcute]sicamente", " ", "debe", " ", "ser", " ", "un", " ", 
         "eritrocito", " ", "bic\[OAcute]ncavo", " ", "real"}]}], "*)"}], 
      "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "5.", " ", "Ejecutar", " ", "el", " ", "algoritmo", " ", 
     "num\[EAcute]rico", " ", "para", " ", "encontrar", " ", "la", " ", 
     "soluci\[OAcute]n", " ", "\[UAcute]nica"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"solucion", "=", 
    RowBox[{"NMinimize", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"funcionError", ",", "restricciones"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c"}], "}"}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "6.", " ", "Extraer", " ", "los", " ", "valores", " ", "\[OAcute]ptimos", 
     " ", "encontrados", " ", "por", " ", "Mathematica"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"valoresOptimos", "=", 
    RowBox[{"solucion", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "7.", " ", "Graficar", " ", "ambas", " ", "curvas", " ", "juntas", " ", 
     "para", " ", "comprobar", " ", "visualmente", " ", "el", " ", "ajuste"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"zEF", "[", "x", "]"}], ",", 
       RowBox[{
        RowBox[{"zCas", "[", 
         RowBox[{"x", ",", "a", ",", "b", ",", "c"}], "]"}], "/.", " ", 
        "valoresOptimos"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "Rmax"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Blue", ",", 
          RowBox[{"Thickness", "[", "0.005", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"Thickness", "[", "0.005", "]"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Evans & Fung (Emp\[IAcute]rica)\>\"", ",", 
        "\"\<Cassini (Optimizada)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Radio x (\[Mu]m)\>\"", ",", "\"\<Altura z (\[Mu]m)\>\""}],
        "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Ajuste por M\[IAcute]nimos Cuadrados\>\""}]}], 
    "]"}]}]}]], "Input",
