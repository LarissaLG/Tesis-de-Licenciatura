Cell[CellGroupData[{

Cell["Comparaci\[OAcute]n geometr\[IAcute]as (original vs Real)", "Subsection",
 CellChangeTimes->{{3.9912268235486555`*^9, 
  3.991226853985199*^9}},ExpressionUUID->"8bed4246-60a5-4b0d-98c0-\
25fbc20b0e61"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"comparacionGeometrias", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"cassiniTsi", "[", 
         RowBox[{"x", ",", 
          RowBox[{"a", "[", 
           RowBox[{"3.825", ",", "0.71"}], "]"}], ",", "3.825"}], "]"}], ",", 
        "Black"}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"cassiniTsi", "[", 
          RowBox[{"x", ",", 
           RowBox[{"a", "[", 
            RowBox[{"3.825", ",", "0.71"}], "]"}], ",", "3.825"}], "]"}]}], 
        ",", "Black"}], "]"}], ",", "\n", "                            ", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"cassini", "[", 
         RowBox[{"x", ",", "2.6", ",", "2.7", ",", "0.83"}], "]"}], ",", 
        "Orange"}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"cassini", "[", 
          RowBox[{"x", ",", "2.6", ",", "2.7", ",", "0.83"}], "]"}]}], ",", 
        "Orange"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
