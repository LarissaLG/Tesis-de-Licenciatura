        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}]}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]}]}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
