  RowBox[{"(*", 
   RowBox[{"Ecuacion", " ", "Cassini", "  ", "sin", " ", "c"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"cassini", "[", 
     RowBox[{"x_", ",", "a_", ",", "R_"}], "]"}], ":=", 
