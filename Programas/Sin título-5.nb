Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "define", " ", "el", " ", "modelo", " ", "de", " ", "drude"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"epsDrude", "[", 
     RowBox[{"\[Omega]_", ",", "\[Omega]p_", ",", "\[Gamma]_"}], "]"}], ":=", 
    RowBox[{"1", "-", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"(", "\[Omega]p", ")"}], "^", "2"}], 
       RowBox[{"\[Omega]", "*", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "+", " ", 
          RowBox[{"I", " ", "\[Gamma]"}]}], ")"}]}]], ")"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"epsLorentz", "[", 
     RowBox[{"A_", ",", "\[Omega]_", ",", "\[Omega]0_", ",", "\[Gamma]_"}], 
     "]"}], ":=", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"A", "^", "2"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Omega]0", "^", "2"}], "-", 
        RowBox[{"\[Omega]", "^", "2"}], "-", 
        RowBox[{"I", "*", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]", " ", "\[Omega]"}], ")"}]}]}], ")"}]}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Se", " ", "define", " ", "la", " ", "parte", " ", "real", " ", "y", " ", 
     "la", " ", "imaginaria", " ", "del", " ", "\[IAcute]ndice", " ", "de", 
     " ", "refracci\[OAcute]n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsImagDrude", "[", 
      RowBox[{"energy_", ",", "omegaP_", ",", "gamma_"}], "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"epsDrude", "[", 
       RowBox[{"energy", ",", "omegaP", ",", "gamma"}], "]"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsReDrude", "[", 
      RowBox[{"energy_", ",", "omegaP_", ",", "gamma_"}], "]"}], ":=", 
     RowBox[{"Re", "[", 
      RowBox[{"epsDrude", "[", 
       RowBox[{"energy", ",", "omegaP", ",", "gamma"}], "]"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsImagLorentz", "[", 
      RowBox[{"A_", ",", "\[Omega]_", ",", "\[Omega]0_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{"Im", "[", 
      RowBox[{"epsLorentz", "[", 
       RowBox[{"A", ",", "\[Omega]", ",", "\[Omega]0", ",", "\[Gamma]"}], 
       "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epsReLorentz", "[", 
      RowBox[{"A_", ",", "\[Omega]_", ",", "\[Omega]0_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{"Re", "[", 
      RowBox[{"epsLorentz", "[", 
       RowBox[{"A", ",", "\[Omega]", ",", "\[Omega]0", ",", "\[Gamma]"}], 
       "]"}], "]"}]}], ";"}]}]}]], "Input",
