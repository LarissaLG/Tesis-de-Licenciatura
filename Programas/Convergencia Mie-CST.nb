Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Modelo", " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"modelo", " ", "=", " ", 
     RowBox[{
      RowBox[{"a", " ", "*", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x", " ", "-", " ", "x0"}], ")"}], "^", "2"}]}], " ", "/",
          " ", 
         RowBox[{"(", 
          RowBox[{"2", " ", "*", " ", 
           RowBox[{"sigma", "^", "2"}]}], ")"}]}], "]"}]}], " ", "+", " ", 
      "b"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ajuste", " ", "=", " ", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"hola2", ",", " ", "modelo", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a", ",", "0.1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x0", ",", "565"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"sigma", ",", " ", "2"}], "}"}], ",", " ", "b"}], "}"}], 
       ",", " ", "x"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "bestA", ",", " ", "bestX0", ",", " ", "bestSigma", ",", " ", "bestB"}],
       "}"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", " ", "x0", ",", " ", "sigma", ",", " ", "b"}], "}"}],
       " ", "/.", " ", 
      RowBox[{"ajuste", "[", "\"\<BestFitParameters\>\"", "]"}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"4.", " ", "Calculamos", " ", "el", " ", "FWHM"}], " ", "*)"}], 
   "\n", 
   RowBox[{"fwhm", " ", "=", " ", 
    RowBox[{"2", " ", "*", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", " ", "*", " ", 
       RowBox[{"Log", "[", "2", "]"}]}], "]"}], " ", "*", " ", 
     "bestSigma"}]}]}]}]], "Code",
 CellChangeTimes->{{3.9856948925534935`*^9, 3.9856948925534935`*^9}, 
