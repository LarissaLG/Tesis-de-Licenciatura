Cell[BoxData[{
 RowBox[{
  RowBox[{"datosIM", "=", 
   RowBox[{
   "Import", "[", 
    "\"\<C:\\\\Users\\\\Nanoplasmonics\\\\Documents\\\\GitHub\\\\Tesis-de-\
Licenciatura\\\\Funciones_dielectricas\\\\CST\\\\epsEritrocitosData30_Im_Fit.\
csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"datosRE", "=", 
    RowBox[{
    "Import", "[", 
     "\"\<C:\\\\Users\\\\Nanoplasmonics\\\\Documents\\\\GitHub\\\\Tesis-de-\
Licenciatura\\\\Funciones_dielectricas\\\\CST\\\\epsEritrocitosData30_Re_Fit.\
csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Se", " ", "pasa", " ", "de", " ", "longitudes", " ", "de", " ", "onda", 
    " ", "a", " ", "energ\[IAcute]as", " ", "y", " ", "se", " ", "toma", " ", 
    "a", " ", "la", " ", "primera", " ", "columna", " ", "como", " ", "el", 
    " ", "vector", " ", "de", " ", "energ\[IAcute]as"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parteImFit", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"datosIM", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"datosIM", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"parteReFit", "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"datosRE", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"datosRE", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nindexEriFit", "[", "lambda_", "]"}], ":=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{"parteReFit", "[", "lambda", "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"parteImFit", "[", "lambda", "]"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9773375892875853`*^9, 3.9773377381585283`*^9}, {
  3.97733777567002*^9, 3.977337775846187*^9}, {3.977337849319292*^9, 
