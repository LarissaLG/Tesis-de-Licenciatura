Cell[BoxData[{
 RowBox[{
  RowBox[{"errorAbs", "[", 
   RowBox[{"data1_", ",", "data2_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "error", "}"}], ",", "\[IndentingNewLine]", 
